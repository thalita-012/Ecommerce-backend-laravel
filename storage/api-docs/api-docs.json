            "delete": {
                "tags": [
                    "Wishlist"
                ],
                "summary": "Remove an item from the wishlist",
                "operationId": "removeWishlist",
                "parameters": [
                    {
                        "name": "wishlist",
                        "in": "path",
                        "description": "Wishlist item ID",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 201
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Removed from wishlist",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/MessageResponse"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
