            "get": {
                "tags": [
                    "Wishlist"
                ],
                "summary": "Check if a product is in the wishlist",
                "operationId": "checkWishlist",
                "parameters": [
                    {
                        "name": "productId",
                        "in": "path",
                        "description": "Product ID",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 10
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Wishlist status",
                        "content": {
                            "application/json": {
